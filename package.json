{
  "name": "anghami-plus",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "eslint src --ext .ts",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.json\" \".*.json\"",
    "format:write": "prettier --write \"src/**/*.ts\" \"*.json\" \".*.json\"",
    "test": "jest --passWithNoTests",
    "build": "tsc --noEmit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ]
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
